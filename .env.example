# Bot API keys
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Twilio (used by both the bot and the PHP dashboard via getenv())
TWILIO_SID=
TWILIO_TOKEN=

# URL of this bot server — used by the PHP dashboard to set Twilio's VoiceUrl
# In production: https://yourdomain.com/bot
# In dev: your ngrok URL
BOT_WEBHOOK_URL=
